/* Modern Minimal Website Theme - Complete Redesign */
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap');

:root {
  /* Core Colors */
  --bg-primary: #040816;
  --bg-secondary: #0b1228;
  --bg-tertiary: #131a35;
  --bg-card: rgba(11, 18, 40, 0.76);
  --bg-overlay: rgba(4, 8, 22, 0.72);

  /* Electric Blue / Purple Accents */
  --accent-primary: #5ee7ff;
  --accent-secondary: #8b5cf6;
  --accent-light: #b794f6;
  --accent-glow: rgba(94, 231, 255, 0.22);
  --accent-hover: rgba(94, 231, 255, 0.12);
  --highlight-cta: #7c3aed;

  /* Glass Borders */
  --border-primary: rgba(255, 255, 255, 0.14);
  --border-secondary: rgba(255, 255, 255, 0.1);
  --border-light: rgba(255, 255, 255, 0.08);

  /* Text Colors */
  --text-primary: #f8fbff;
  --text-secondary: #dce7ff;
  --text-muted: #8ea2bf;
  --text-accent: #5ee7ff;

  /* Status Colors */
  --status-online: #4ade80;
  --status-offline: #fb7185;
  --status-warning: #fbbf24;

  /* Shadows */
  --shadow-sm: 0 8px 24px rgba(2, 6, 23, 0.2);
  --shadow-md: 0 16px 45px rgba(2, 6, 23, 0.3);
  --shadow-lg: 0 24px 60px rgba(2, 6, 23, 0.4);
  --shadow-xl: 0 30px 90px rgba(2, 6, 23, 0.55);
  --shadow-glow: 0 0 0 1px rgba(94, 231, 255, 0.22), 0 24px 60px rgba(94, 231, 255, 0.16);

  /* Gradients */
  --gradient-primary: linear-gradient(135deg, #5ee7ff 0%, #8b5cf6 100%);
  --gradient-secondary: linear-gradient(135deg, rgba(255,255,255,0.16) 0%, rgba(255,255,255,0.06) 100%);
  --gradient-accent: linear-gradient(135deg, rgba(94, 231, 255, 0.18) 0%, rgba(139, 92, 246, 0.2) 100%);

  /* Spacing */
  --spacing-xs: 0.25rem;
  --spacing-sm: 0.5rem;
  --spacing-md: 1rem;
  --spacing-lg: 1.5rem;
  --spacing-xl: 2rem;
  --spacing-2xl: 3rem;

  /* Border Radius */
  --radius-sm: 0.5rem;
  --radius-md: 0.75rem;
  --radius-lg: 1rem;
  --radius-xl: 1.25rem;
  --radius-2xl: 1.5rem;

  /* Transitions */
  --transition-fast: 0.15s ease-in-out;
  --transition-normal: 0.3s ease-in-out;
  --transition-slow: 0.5s ease-in-out;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-height: 100vh;
  font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: var(--text-primary);
  background:
    radial-gradient(circle at top left, rgba(94, 231, 255, 0.16), transparent 24%),
    radial-gradient(circle at top right, rgba(139, 92, 246, 0.16), transparent 24%),
    var(--bg-primary);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(14px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Typography */
h1, h2, h3, h4, h5, h6 {
  font-family: 'Poppins', sans-serif;
  font-weight: 600;
  line-height: 1.2;
  margin: 0 0 var(--spacing-md) 0;
  color: var(--text-primary);
}

h1 {
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
}

h2 {
  font-size: clamp(1.5rem, 4vw, 2.5rem);
  font-weight: 600;
  letter-spacing: -0.01em;
}

h3 {
  font-size: clamp(1.25rem, 3vw, 2rem);
  font-weight: 600;
}

h4 {
  font-size: clamp(1.125rem, 2.5vw, 1.5rem);
  font-weight: 500;
}

h5 {
  font-size: 1.25rem;
  font-weight: 500;
}

h6 {
  font-size: 1.125rem;
  font-weight: 500;
}

p {
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  line-height: 1.7;
  margin: 0 0 var(--spacing-md) 0;
  color: var(--text-secondary);
}

small {
  font-size: 0.875rem;
  color: var(--text-muted);
}

/* Layout Grid System */
.container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--spacing-lg);
}

.grid {
  display: grid;
  gap: var(--spacing-lg);
}

.grid-cols-1 { grid-template-columns: repeat(1, 1fr); }
.grid-cols-2 { grid-template-columns: repeat(2, 1fr); }
.grid-cols-3 { grid-template-columns: repeat(3, 1fr); }
.grid-cols-4 { grid-template-columns: repeat(4, 1fr); }

/* Header */
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(4, 8, 22, 0.75);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  padding: var(--spacing-md) 0;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.24);
}

.header-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--spacing-lg);
}

.brand a {
  font-family: 'Poppins', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--accent-primary);
  text-decoration: none;
  transition: var(--transition-normal);
}

.brand a:hover {
  color: var(--accent-secondary);
  transform: translateY(-1px);
}

/* Navigation */
.site-nav ul {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  list-style: none;
  margin: 0;
  padding: 0;
}

.site-nav a {
  display: inline-flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  color: var(--text-secondary);
  text-decoration: none;
  border-radius: var(--radius-lg);
  transition: var(--transition-normal);
  font-weight: 500;
  position: relative;
  overflow: hidden;
}

.site-nav a:hover {
  color: var(--accent-primary);
  background: var(--accent-hover);
  transform: translateY(-1px);
}

.site-nav a::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, var(--accent-glow), transparent);
  transition: left var(--transition-slow);
}

.site-nav a:hover::before {
  left: 100%;
}

/* Tabs and Toggle Controls */
[role="tablist"],
.nav-tabs,
.tab-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  align-items: center;
}

[role="tab"],
.nav-tabs .nav-link,
.tab-button,
.tab-item {
  background: rgba(255, 255, 255, 0.05);
  color: var(--text-secondary);
  border: 1px solid var(--border-secondary);
  border-radius: var(--radius-lg);
  padding: 0.7rem 1rem;
  font-weight: 500;
  transition: var(--transition-normal);
}

[role="tab"]:hover,
.nav-tabs .nav-link:hover,
.tab-button:hover,
.tab-item:hover {
  color: var(--accent-primary);
  background: rgba(94, 231, 255, 0.12);
  border-color: rgba(94, 231, 255, 0.3);
}

[role="tab"][aria-selected="true"],
[role="tab"].active,
.nav-tabs .nav-link.active,
.tab-button.active,
.tab-item.active {
  background: linear-gradient(135deg, rgba(94, 231, 255, 0.2), rgba(139, 92, 246, 0.2));
  color: var(--text-primary);
  border-color: rgba(94, 231, 255, 0.35);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 8px 24px rgba(2, 6, 23, 0.2);
}

/* Buttons */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-sm) var(--spacing-lg);
  border-radius: var(--radius-lg);
  font-family: 'Inter', sans-serif;
  font-weight: 500;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: var(--transition-normal);
  position: relative;
  overflow: hidden;
  min-height: 44px;
}

.btn-primary {
  background: var(--gradient-primary);
  color: white;
  box-shadow: var(--shadow-md);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}

.btn-primary::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left var(--transition-slow);
}

.btn-primary:hover::before {
  left: 100%;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.06);
  color: var(--text-primary);
  border: 1px solid var(--border-primary);
  backdrop-filter: blur(10px);
}

.btn-secondary:hover {
  background: var(--accent-hover);
  border-color: var(--accent-primary);
  color: var(--accent-primary);
}

/* Page Layout */
.page-shell {
  min-height: calc(100vh - 200px);
  padding: var(--spacing-2xl) 0;
}

/* Cards */
.card {
  background: var(--bg-card);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  transition: var(--transition-normal);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.card:hover {
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-glow);
  transform: translateY(-2px);
}

.card-header {
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--border-light);
  background: rgba(255, 255, 255, 0.04);
}

.card-body {
  padding: var(--spacing-lg);
}

.card-footer {
  padding: var(--spacing-lg);
  border-top: 1px solid var(--border-light);
  background: rgba(255, 255, 255, 0.04);
}

/* Module Cards */
.module-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: var(--spacing-lg);
  margin: var(--spacing-xl) 0;
}

.module-card {
  background: var(--bg-card);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  transition: var(--transition-normal);
  position: relative;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  display: block;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  animation: fadeUp 0.6s ease both;
}

.module-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradient-primary);
  opacity: 0;
  transition: var(--transition-normal);
}

.module-card:hover::before {
  opacity: 1;
}

.module-card:hover {
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-glow);
  transform: translateY(-4px);
}

.module-title {
  font-family: 'Poppins', sans-serif;
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--accent-primary);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.module-status {
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-md);
  font-weight: 500;
}

.module-description {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.6;
}

/* Form Elements */
.form-group {
  margin-bottom: var(--spacing-lg);
}

.form-label {
  display: block;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
}

input, textarea, select {
  width: 100%;
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-md);
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: 'Inter', sans-serif;
  font-size: 1rem;
  transition: var(--transition-normal);
  min-height: 44px;
}

input:focus, textarea:focus, select:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3px var(--accent-glow);
}

input::placeholder, textarea::placeholder {
  color: var(--text-muted);
}

/* Status Indicators */
.status-indicator {
  position: relative;
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-right: var(--spacing-sm);
}

.status-indicator.online {
  background: var(--status-online);
  box-shadow: 0 0 6px var(--status-online);
}

.status-indicator.offline {
  background: var(--status-offline);
  box-shadow: 0 0 6px var(--status-offline);
}

.status-indicator.warning {
  background: var(--status-warning);
  box-shadow: 0 0 6px var(--status-warning);
}

/* Dashboard Stats */
.dashboard-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: var(--spacing-lg);
  margin: var(--spacing-xl) 0;
}

.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border-primary);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: var(--transition-normal);
}

.stat-card:hover {
  border-color: var(--accent-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.stat-number {
  font-family: 'Poppins', sans-serif;
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--accent-primary);
  margin-bottom: var(--spacing-sm);
}

.stat-label {
  font-size: 0.875rem;
  color: var(--text-secondary);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* Chat Interface */
.messages {
  background: var(--bg-secondary);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  max-height: 500px;
  overflow-y: auto;
  border: 1px solid var(--border-primary);
}

.message-row {
  margin-bottom: var(--spacing-md);
  animation: slideIn 0.3s ease-out;
}

.message-bubble {
  padding: var(--spacing-md) var(--spacing-lg);
  border-radius: var(--radius-lg);
  max-width: 80%;
  line-height: 1.6;
  position: relative;
  box-shadow: var(--shadow-sm);
}

.message-bubble.bot {
  background: var(--bg-primary);
  border: 1px solid var(--border-primary);
  margin-right: auto;
}

.message-bubble.you {
  background: var(--gradient-primary);
  margin-left: auto;
  color: white;
}

.message-bubble strong {
  color: var(--accent-primary);
  font-weight: 600;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Loading Spinner */
.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--border-primary);
  border-top: 3px solid var(--accent-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* Footer */
.site-footer {
  background: var(--bg-secondary);
  border-top: 1px solid var(--border-primary);
  padding: var(--spacing-2xl) 0;
  text-align: center;
  color: var(--text-muted);
}

/* Responsive Design */
@media (max-width: 768px) {
  .header-container {
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .site-nav ul {
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-xs);
  }

  .site-nav a {
    padding: var(--spacing-xs) var(--spacing-sm);
    font-size: 0.875rem;
  }

  .module-grid {
    grid-template-columns: 1fr;
  }

  .dashboard-stats {
    grid-template-columns: repeat(2, 1fr);
  }

  .page-shell {
    padding: var(--spacing-lg) 0;
  }

  .container {
    padding: 0 var(--spacing-md);
  }
}

@media (max-width: 480px) {
  .dashboard-stats {
    grid-template-columns: 1fr;
  }

  h1 {
    font-size: 2rem;
  }

  h2 {
    font-size: 1.75rem;
  }
}

/* Accessibility */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* Focus states for keyboard navigation */
.btn:focus,
.site-nav a:focus,
input:focus,
textarea:focus,
select:focus {
  outline: 2px solid var(--accent-primary);
  outline-offset: 2px;
}

/* High contrast mode support */
@media (prefers-contrast: high) {
  :root {
    --border-primary: #000000;
    --text-primary: #000000;
    --text-secondary: #000000;
  }
}

/* Utility Classes */
.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.mb-0 { margin-bottom: 0; }
.mb-1 { margin-bottom: var(--spacing-sm); }
.mb-2 { margin-bottom: var(--spacing-md); }
.mb-3 { margin-bottom: var(--spacing-lg); }
.mb-4 { margin-bottom: var(--spacing-xl); }

.mt-0 { margin-top: 0; }
.mt-1 { margin-top: var(--spacing-sm); }
.mt-2 { margin-top: var(--spacing-md); }
.mt-3 { margin-top: var(--spacing-lg); }
.mt-4 { margin-top: var(--spacing-xl); }

.d-flex { display: flex; }
.d-block { display: block; }
.d-none { display: none; }

.justify-center { justify-content: center; }
.align-center { align-items: center; }
.align-start { align-items: flex-start; }
.align-end { align-items: flex-end; }

.w-full { width: 100%; }
.h-full { height: 100%; }

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 8px;
}

::-webkit-scrollbar-track {
  background: var(--bg-secondary);
}

::-webkit-scrollbar-thumb {
  background: var(--accent-primary);
  border-radius: var(--radius-sm);
}

::-webkit-scrollbar-thumb:hover {
  background: var(--accent-secondary);
}
